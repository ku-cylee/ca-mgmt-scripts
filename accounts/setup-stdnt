#!/bin/bash

BASE_DIR=/home/stdnt

function echo_error {
    echo -e "\033[91mERR:\033[0m $1"
    return 0
}

function echo_progress {
    echo -e "\033[94mProgress:\033[0m $1"
    return 0
}

# Abort if non-root user
if [ "$(id -u)" -ne 0 ]; then
    echo_error "A \033[1mroot privilege\033[0m is required to run this script." >&2
    exit 1
fi

if [ -z "$1" ]; then
    echo_error "Provide \033[1musername and secret key list file\033[0m generated by accounts/generate-secrets"
    exit 1
fi

INPUT_FILE_PATH=$1

if [ -z "$(getent group stdnt)" ]; then
    echo_progress "Create student group"
    groupadd stdnt
fi

if ! [ -d "$BASE_DIR" ]; then
    echo_error "Directory \033[1m/home/stdnt\033[0m does not exist. Create and mount drive in advance."
    mkdir $BASE_DIR
fi

cat $INPUT_FILE_PATH | while read LINE; do
    echo_progress "Setting up for student \033[4m$USERNAME\033[0m"
    if [[ "$LINE" =~ ([a-z0-9-]+),([a-z0-9]+) ]]; then
        USERNAME=${BASH_REMATCH[1]}
        SECRET_KEY=${BASH_REMATCH[2]}
        ./accounts/single-stdnt "$USERNAME" "$SECRET_KEY"
    else
        echo_error "Invalid line \033[4m\"$LINE\"\033[0m detected... Skipping."
    fi
done
